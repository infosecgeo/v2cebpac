# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Backend URL
BACKEND_URL=https://api.example.com

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_RANDOM_256BIT_HEX_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
ADMIN_2FA_ENABLED=false

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHANNEL_ID=-1001234567890
TELEGRAM_NOTIFICATION_CHANNEL_ID=-1001234567890
TELEGRAM_WEBHOOK_URL=https://api.example.com/telegram/webhook

# HTTPS Configuration (optional)
HTTPS_ENABLED=false
HTTPS_CERT_PATH=/path/to/cert.pem
HTTPS_KEY_PATH=/path/to/key.pem

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Session Configuration
SESSION_TIMEOUT_HOURS=24
SESSION_HEARTBEAT_INTERVAL_MS=30000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Payment Processor (Go Server)
PAYMENT_PROCESSOR_URL=http://localhost:5000

# Database
DB_PATH=./storage/db
BACKUP_PATH=./storage/backups
